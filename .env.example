# ============================================
# Watkins AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ==================== CORE ====================
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ==================== DATABASE ====================
DATABASE_URL=postgresql://watkins:watkins_password@localhost:5432/watkins_ai?schema=public

# ==================== JWT ====================
# IMPORTANT: Change this in production! Use a strong random string (64+ chars)
JWT_SECRET=change-me-in-production-use-a-strong-random-string
JWT_EXPIRES_IN=7d

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== AZURE OPENAI ====================
# Get these from Azure Portal > Azure OpenAI resource > Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ==================== STRIPE ====================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products/prices in Stripe Dashboard, then paste Price IDs here
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_DFY_BUILDER=price_...

# ==================== SENDGRID ====================
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ==================== TWILIO ====================
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ==================== SHOPIFY ====================
# Create a Shopify app at https://partners.shopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ==================== WOOCOMMERCE ====================
# Generated in WP Admin > WooCommerce > Settings > Advanced > REST API
WOOCOMMERCE_CONSUMER_KEY=ck_...
WOOCOMMERCE_CONSUMER_SECRET=cs_...

# ==================== ENCRYPTION ====================
# Used to encrypt stored API keys. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ==================== FRONTEND (.env.local) ====================
# These go in frontend/.env.local, not this file
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
